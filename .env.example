APP_NAME=AI-Trader
APP_ENV=dev
DEBUG=false

API_HOST=127.0.0.1
API_PORT=8000

TIMEZONE=America/New_York

TRADING_MODE=paper
ENABLE_LIVE_TRADING=false

STOCKS_ENABLED=true
CRYPTO_ENABLED=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_trader
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

TRADIER_BASE_URL=https://api.tradier.com
TRADIER_TOKEN=
TRADIER_ACCOUNT_ID=

KRAKEN_BASE_URL=https://api.kraken.com
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Phase 11B / 12 historical research settings
ALPACA_MARKET_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DEFAULT_FEED=iex
ALPACA_RATE_LIMIT_PER_MINUTE=180
ALPACA_STOCK_BATCH_SIZE=100
CRYPTO_HISTORY_DIR=crypto-history
